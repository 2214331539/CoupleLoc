# Use your computer LAN IP when testing on a physical Android device.
# Example: http://192.168.1.20:8000
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
EXPO_PUBLIC_WS_BASE_URL=ws://127.0.0.1:8000

# Needed for standalone Android builds using react-native-maps.
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=

