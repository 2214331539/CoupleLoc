APP_NAME=CoupleLoc API
ENVIRONMENT=local
DEBUG=true

# Use a strong random value in real deployments.
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

DATABASE_URL=postgresql+asyncpg://coupleloc:coupleloc@localhost:5432/coupleloc
AUTO_CREATE_TABLES=false
LOW_BATTERY_THRESHOLD=0.2

# Local development: "log" returns the verification code in API responses.
# Real Aliyun SMS sending: set SMS_PROVIDER=aliyun.
SMS_PROVIDER=log
SMS_CODE_EXPIRE_MINUTES=5
SMS_RESEND_COOLDOWN_SECONDS=60
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_TEMPLATE_CODE_KEY=code
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_STS_ENDPOINT=sts.cn-shanghai.aliyuncs.com

# Comma-separated origins. Use your Expo dev URL or "*" for local-only testing.
CORS_ORIGINS=*
