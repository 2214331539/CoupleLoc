APP_NAME=CoupleLoc API
ENVIRONMENT=local
DEBUG=true

# Use a strong random value in real deployments.
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

DATABASE_URL=postgresql+asyncpg://coupleloc:coupleloc@localhost:5432/coupleloc
AUTO_CREATE_TABLES=false
LOW_BATTERY_THRESHOLD=0.2

# Comma-separated origins. Use your Expo dev URL or "*" for local-only testing.
CORS_ORIGINS=*
